# .env.example — Copy to .env and fill in values
# Database
DB_HOST=timescaledb
DB_USER=postgres
DB_PASS=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_HOST=redis

# Delta Exchange
ENCRYPTION_KEY=CHANGE_ME_32_CHAR_ENCRYPTION_KEY

# Telegram
TELEGRAM_BOT_TOKEN=
