# AI (optional — for agent features)
ANTHROPIC_API_KEY=
FRED_API_KEY=DEMO_KEY

# JWT
JWT_SECRET=CHANGE_ME_BASE64_ENCODED_SECRET

# Monitoring
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
